# Application
APP_NAME=iex-rtm-forecast
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
MODEL_REGISTRY_DIR=data/models

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iex_rtm
POSTGRES_USER=iex_user
POSTGRES_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql+psycopg2://iex_user:change_me_secure_password@localhost:5432/iex_rtm

# Forecasting
FORECAST_HORIZON_BLOCKS=96
BLOCK_MINUTES=15
TRAIN_TEST_SPLIT_DATE=2025-06-01
MIN_TRAINING_ROWS=5000
ENSEMBLE_WEIGHTS=xgboost:0.35,lightgbm:0.35,catboost:0.30

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_KEY=dev-api-key-change-in-production

# Streamlit
STREAMLIT_SERVER_PORT=8501
FORECAST_API_BASE_URL=http://localhost:8000
